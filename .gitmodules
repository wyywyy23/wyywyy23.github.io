[submodule "static/css/vendor/academicons"]
	path = static/css/vendor/academicons
	url = https://github.com/jpswalsh/academicons.git
	ignore = untracked
[submodule "static/css/vendor/fontawesome"]
	path = static/css/vendor/fontawesome
	url = https://github.com/FortAwesome/Font-Awesome.git
	ignore = untracked
[submodule "static/css/vendor/bootstrap-icons"]
	path = static/css/vendor/bootstrap-icons
	url = https://github.com/twbs/icons.git
	ignore = untracked
