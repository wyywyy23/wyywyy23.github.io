{
  "name": "wangyy.phd",
  "version": "1.0.0",
  "private": true,
  "description": "My academic website",
  "author": "Yuyang Wang",
  "license": "MIT",
  "engines": {
    "node": ">=16.16.0"
  },
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "create": "exec-bin node_modules/.bin/hugo/hugo new",
    "dev": "exec-bin node_modules/.bin/hugo/hugo server --bind=0.0.0.0 --disableFastRender --baseURL=http://localhost --noHTTPCache",
    "dev:drafts": "exec-bin node_modules/.bin/hugo/hugo server --bind=0.0.0.0 --disableFastRender --baseURL=http://localhost --noHTTPCache --buildDrafts",
    "lint": "npm run -s lint:scripts && npm run -s lint:styles && npm run -s lint:markdown",
    "lint-fix": "npm run -s lint:scripts-fix && npm run -s lint:styles-fix && npm run -s lint:markdown-fix",
    "lint:scripts": "eslint assets/js config functions",
    "lint:scripts-fix": "eslint --fix assets/js config functions",
    "lint:styles": "stylelint \"assets/scss/**/*.{css,sass,scss,sss,less}\"",
    "lint:styles-fix": "stylelint --fix \"assets/scss/**/*.{css,sass,scss,sss,less}\"",
    "lint:markdown": "markdownlint-cli2 \"*.md\" \"content/**/*.md\"",
    "lint:markdown-fix": "markdownlint-cli2-fix \"*.md\" \"content/**/*.md\"",
    "test": "npm run -s lint-fix",
    "build": "exec-bin node_modules/.bin/hugo/hugo --minify",
    "preview": "http-server --gzip --brotli --ext=html --cors",
    "clean": "npm run clean:build && npm run clean:lint && npm run clean:install",
    "clean:build": "shx rm -rf public resources .hugo_build.lock",
    "clean:install": "shx rm -rf node_modules package-lock.json yarn.lock pnpm-lock.yaml",
    "clean:lint": "shx rm -rf .eslintcache .stylelintcache",
    "copy:katex-fonts": "shx cp node_modules/katex/dist/fonts/* ./static/fonts/",
    "preinfo": "npm version",
    "info": "npm list",
    "postinfo": "exec-bin node_modules/.bin/hugo/hugo version",
    "postinstall": "shx rm -rf node_modules/.bin/hugo && shx mkdir node_modules/.bin/hugo && shx cp node_modules/gethyas/node_modules/.bin/hugo/* node_modules/.bin/hugo"
  },
  "dependencies": {
    "@hyas/doks-core": "^1.1.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.23",
    "@babel/core": "^7.23",
    "@babel/preset-env": "^7.23",
    "@docsearch/js": "^3.5",
    "@fullhuman/postcss-purgecss": "^5.0",
    "@hyas/images": "^2.0.3",
    "auto-changelog": "^2.4",
    "autoprefixer": "^10.4",
    "bootstrap": "^5.3.2",
    "clipboard": "^2.0",
    "dotenv": "^16.3",
    "encoding": "^0.1.13",
    "eslint": "^8.54",
    "exec-bin": "^1.0.0",
    "highlight.js": "^11.9",
    "hugo-installer": "^4.0",
    "instant.page": "^5.2",
    "katex": "^0.16",
    "lazysizes": "^5.3",
    "markdownlint-cli2": "^0.11.0",
    "netlify-plugin-submit-sitemap": "^0.4.0",
    "node-fetch": "^3.3",
    "plausible-tracker": "^0.3",
    "postcss": "^8.4",
    "postcss-cli": "^11.0",
    "purgecss-whitelister": "^2.4",
    "shx": "^0.3",
    "stylelint": "^14.9",
    "stylelint-config-standard-scss": "^6.1"
  },
  "otherDependencies": {
    "hugo": "0.101.0"
  }
}
